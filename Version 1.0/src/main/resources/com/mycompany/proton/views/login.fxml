<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #e9ecef;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.proton.controller.LoginController">
    <children>
        <HBox layoutX="14.4" layoutY="35.0" prefHeight="461.0" prefWidth="774.0" style="-fx-background-color: #ffffff; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 15, 0, 0, 5);" AnchorPane.bottomAnchor="33.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="12.0" AnchorPane.topAnchor="35.0">
            <children>
                <VBox alignment="CENTER" prefHeight="460.0" prefWidth="382.0" spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 16 0 0 16; -fx-border-color: #dee2e6; -fx-border-width: 0 1 0 0; -fx-border-radius: 16 0 0 16;">
                    <children>
                        <ImageView fitHeight="160.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/icone.png" />
                            </image>
                        </ImageView>
                        <Label text="PROTON" textFill="#2b3035">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Label>
                        <Label text="ERP &amp; Cloud Management" textFill="#6c757d">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                          <Label text="© 2026 - Desenvolvido por Gabriel Levi  · Todos os direitos reservados." textFill="#adb5bd">
                              <font>
                                  <Font size="11.0" />
                              </font>
                          </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" prefHeight="430.0" prefWidth="350.0" spacing="15.0" style="-fx-padding: 30;">
                    <children>
                        <Label text="Autenticação Corporativa" textFill="#212529">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </Label>
                    
                        <VBox fx:id="boxLogin" maxWidth="300.0" spacing="8.0">
                            <children>
                                <Label text="E-mail Corporativo:" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtEmail" prefHeight="40.0" promptText="usuario@fortestecnologia.com.br" style="-fx-background-radius: 8; -fx-border-color: #ced4da; -fx-border-radius: 8; -fx-background-color: white;" />
                        
                                <Label text="Senha de Acesso:" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                    <VBox.margin>
                                        <Insets top="5.0" />
                                    </VBox.margin>
                                </Label>
                                <PasswordField fx:id="txtSenha" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 8; -fx-border-color: #ced4da; -fx-border-radius: 8; -fx-background-color: white;" />

                                <HBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="300.0">
                                    <children>
                                        <CheckBox fx:id="chkLembrar" mnemonicParsing="false" text="Lembrar meu e-mail" textFill="#495057" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Hyperlink fx:id="linkEsqueciSenha" onAction="#esqueciMinhaSenha" text="Esqueci a senha" textFill="#0d6efd" underline="true" />
                                    </children>
                                    <VBox.margin>
                                        <Insets top="2.0" />
                                    </VBox.margin>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox fx:id="boxNovaSenha" managed="false" maxWidth="300.0" spacing="8.0" visible="false">
                            <children>
                                <Label text="⚠️ Primeiro Acesso - Crie uma Nova Senha" textFill="#dc3545">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <PasswordField fx:id="txtNovaSenha" prefHeight="40.0" promptText="Digite a Nova Senha" style="-fx-background-radius: 8; -fx-border-color: #ced4da; -fx-border-radius: 8; -fx-background-color: white;" />
                                <PasswordField fx:id="txtConfirmaSenha" prefHeight="40.0" promptText="Confirme a Nova Senha" style="-fx-background-radius: 8; -fx-border-color: #ced4da; -fx-border-radius: 8; -fx-background-color: white;" />
                            </children>
                        </VBox>

                        <Button fx:id="btnEntrar" defaultButton="true" mnemonicParsing="false" onAction="#entrar" prefHeight="42.0" prefWidth="300.0" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="Acessar Sistema">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>
                    
                        <Button fx:id="btnSair" cancelButton="true" mnemonicParsing="false" onAction="#sair" prefHeight="42.0" prefWidth="300.0" style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ced4da; -fx-cursor: hand; -fx-font-weight: bold;" text="Sair / Fechar">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>

                        <Label fx:id="lblErro" maxWidth="300.0" textAlignment="CENTER" textFill="#dc3545" visible="false" wrapText="true">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        
                        <Region VBox.vgrow="ALWAYS" />
                        
                        <HBox alignment="BOTTOM_CENTER" prefHeight="30.0" prefWidth="300.0" spacing="20.0">
                            <children>
                                <Hyperlink onAction="#abrirTelaConfigBancoManualmente" text="⚙ Configurar Acesso ao Banco de Dados" textFill="#6c757d" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
