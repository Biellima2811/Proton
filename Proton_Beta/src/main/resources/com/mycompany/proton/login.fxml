<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.proton.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="50.0" layoutY="50.0" prefHeight="300.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="40.0">
         <children>
            <Label text="PROTON" textFill="#2b3035">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label text="Autenticação Corporativa" textFill="#6c757d">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <VBox maxWidth="300.0" spacing="5.0">
               <children>
                  <Label text="E-mail do Técnico:" textFill="#495057">
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtEmail" prefHeight="40.0" promptText="usuario@fortestecnologia.com.br" style="-fx-background-radius: 4;" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#entrar" prefHeight="40.0" prefWidth="300.0" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Acessar Sistema">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
            <Label fx:id="lblErro" textFill="#dc3545" visible="false">
               <font>
                  <Font size="12.0" />
               </font>
            </Label>
         </children>
      </VBox>
   </children>
</AnchorPane>