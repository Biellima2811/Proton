<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane 
    maxHeight="-Infinity" 
    maxWidth="-Infinity" 
    minHeight="-Infinity" 
    minWidth="-Infinity" 
    prefHeight="700.0" 
    prefWidth="1200.0" 
    xmlns="http://javafx.com/javafx/26" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="com.mycompany.proton.PrimaryController"
    stylesheets="@estilo.css">
   <left>
      <VBox prefHeight="600.0" prefWidth="240.0" style="-fx-background-color: #2b3035;" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" prefHeight="70.0" prefWidth="240.0" text="PROTON" textFill="WHITE">
               <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            
            <Button fx:id="btnDedicados" mnemonicParsing="false" onAction="#abaClientesDedicados" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: #3b4248; -fx-text-fill: white; -fx-alignment: center-left; -fx-border-color: #0d6efd; -fx-border-width: 0 0 0 4;" text="  [SkyOne] Dedicados">
               <font><Font name="System Bold" size="13.0" /></font>
            </Button>
            <Button fx:id="btnCompartilhados" mnemonicParsing="false" onAction="#abaClientesCompartilhados" prefHeight="50.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-text-fill: #adb5bd; -fx-alignment: center-left;" text="  [Nuvem] Compartilhados">
               <font><Font name="System Bold" size="13.0" /></font>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #f8f9fa;" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblTituloAba" layoutX="32.0" layoutY="28.0" text="Clientes Dedicados (SKYONE)">
               <font><Font name="System Bold" size="22.0" /></font>
            </Label>
            
            <StackPane layoutX="32.0" layoutY="141.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="100.0">
               <children>
                  
                  <TableView fx:id="tabelaDedicados">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                      <TableColumn fx:id="colNome" prefWidth="230.0" text="Razão Social" />
                      <TableColumn fx:id="colCnpj" prefWidth="130.0" text="CNPJ" />
                      <TableColumn fx:id="colQntServer" prefWidth="70.0" text="Servers" />
                      <TableColumn fx:id="colAd" prefWidth="120.0" text="AD" />
                      <TableColumn fx:id="colAmbiente" prefWidth="80.0" text="Ambiente" />
                      <TableColumn fx:id="colVpn" prefWidth="50.0" text="VPN" />
                      <TableColumn fx:id="colSgbd" prefWidth="70.0" text="SGBD" />
                    </columns>
                  </TableView>

                  <TableView fx:id="tabelaCompartilhados" visible="false">
                    <columns>
                      <TableColumn fx:id="colCId" prefWidth="40.0" text="ID" />
                      <TableColumn fx:id="colCTipoNuvem" prefWidth="80.0" text="Nuvem" />
                      <TableColumn fx:id="colCPod" prefWidth="50.0" text="POD" />
                      <TableColumn fx:id="colCData" prefWidth="80.0" text="Criação" />
                      <TableColumn fx:id="colCRazao" prefWidth="200.0" text="Razão Social" />
                      <TableColumn fx:id="colCCnpj" prefWidth="130.0" text="CNPJ / CPF" />
                      <TableColumn fx:id="colCAg" prefWidth="80.0" text="Cod AG" />
                      <TableColumn fx:id="colCPasta" prefWidth="100.0" text="Pasta Rede" />
                      <TableColumn fx:id="colCContato" prefWidth="100.0" text="Contato" />
                      <TableColumn fx:id="colCUsuarios" prefWidth="60.0" text="Usuários" />
                      <TableColumn fx:id="colCSistemas" prefWidth="150.0" text="Sistemas" />
                      <TableColumn fx:id="colCStatus" prefWidth="80.0" text="Status" />
                      <TableColumn fx:id="colCBanco" prefWidth="80.0" text="SGBD" />
                    </columns>
                  </TableView>

               </children>
            </StackPane>

         </children>
      </AnchorPane>
   </center>
</BorderPane>