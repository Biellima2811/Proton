<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.proton.ConfigBancoController">
   <children>
      <VBox layoutX="66.0" layoutY="50.0" prefHeight="300.0" prefWidth="450.0" spacing="20.0">
         <children>
            <Label prefHeight="27.0" prefWidth="288.0" text="Configuração do Banco do Dados" textAlignment="JUSTIFY">
               <font>
                  <Font name="System Bold Italic" size="18.0" />
               </font>
            </Label>
            
            <TextField fx:id="txtIp" prefHeight="26.0" prefWidth="425.0" promptText="IP do Servidor (ex: 10.10.x.x)" />
            
            <TextField fx:id="txtNomeBanco" prefHeight="40.0" prefWidth="393.0" promptText="Nome do Banco de Dados">
               <font>
                  <Font name="System Bold Italic" size="18.0" />
               </font>
            </TextField>
            
            <TextField fx:id="txtCaminhoRede" promptText="Caminho da Rede (ex: \10.10.x.x\c$\banco)" />
            
            <Button mnemonicParsing="false" onAction="#salvarConfiguracao" text="Testar Conexão e Salvar" />
         </children>
      </VBox>
   </children>
</AnchorPane>