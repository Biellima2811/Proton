<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.proton.controller.FormAuditoriaController">
    <children>
        <Label layoutX="20.0" layoutY="20.0" text="Relatório Geral de Auditoria do Sistema" textFill="#2b3035">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        
        <DatePicker fx:id="dpFiltroData" layoutX="20.0" layoutY="60.0" prefHeight="26.0" prefWidth="140.0" promptText="Filtrar por Data" />
        <TextField fx:id="txtFiltroTecnico" layoutX="175.0" layoutY="60.0" prefHeight="26.0" prefWidth="200.0" promptText="Técnico / E-mail" />
        <TextField fx:id="txtFiltroDetalhes" layoutX="390.0" layoutY="60.0" prefHeight="26.0" prefWidth="350.0" promptText="Palavra-chave (ex: ABENCOADO, EXCLUSÃO)" />
        <Button layoutX="755.0" layoutY="60.0" mnemonicParsing="false" onAction="#limparFiltros" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-cursor: hand;" text="Limpar Filtros" />

        <TableView fx:id="tabelaLogs" layoutX="20.0" layoutY="100.0" prefHeight="530.0" prefWidth="1060.0">
            <columns>
                <TableColumn fx:id="colDataHora" prefWidth="160.0" text="Data e Hora" />
                <TableColumn fx:id="colUsuario" prefWidth="250.0" text="Técnico / Usuário" />
                <TableColumn fx:id="colAcao" prefWidth="120.0" text="Ação" />
                <TableColumn fx:id="colDetalhes" prefWidth="510.0" text="Detalhes do Registro" />
            </columns>
        </TableView>
    </children>
</AnchorPane>