<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="320.0" prefWidth="450.0" style="-fx-background-color: #2b3035;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.proton.controller.ConfigBancoController">
    <children>
        <AnchorPane style="-fx-background-color: #343a40; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 4);" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>
                <Label layoutX="9.0" layoutY="9.0" text="Parâmetros de Conexão SGBD" textFill="#f8f9fa">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Label layoutX="9.0" layoutY="39.0" text="Configure o destino do banco central da aplicação." textFill="#adb5bd" />

                <Label layoutX="9.0" layoutY="80.0" text="IP do Servidor / Host:" textFill="#f8f9fa" />
                <TextField fx:id="txtIpServidor" layoutX="145.0" layoutY="76.0" prefHeight="26.0" prefWidth="260.0" style="-fx-background-color: #495057; -fx-text-fill: white; -fx-prompt-text-fill: #adb5bd; -fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #6c757d;" />

                <Label layoutX="9.0" layoutY="120.0" text="Nome da Database:" textFill="#f8f9fa" />
                <TextField fx:id="txtNomeBanco" layoutX="145.0" layoutY="116.0" prefHeight="26.0" prefWidth="260.0" style="-fx-background-color: #495057; -fx-text-fill: white; -fx-prompt-text-fill: #adb5bd; -fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #6c757d;" />

                <Label layoutX="9.0" layoutY="160.0" text="Usuário PostgreSQL:" textFill="#f8f9fa" />
                <TextField fx:id="txtUsuarioBD" layoutX="145.0" layoutY="156.0" prefHeight="26.0" prefWidth="260.0" style="-fx-background-color: #495057; -fx-text-fill: white; -fx-prompt-text-fill: #adb5bd; -fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #6c757d;" />

                <Label layoutX="9.0" layoutY="200.0" text="Senha do Banco:" textFill="#f8f9fa" />
                <PasswordField fx:id="txtSenhaBD" layoutX="145.0" layoutY="196.0" prefHeight="26.0" prefWidth="260.0" style="-fx-background-color: #495057; -fx-text-fill: white; -fx-prompt-text-fill: #adb5bd; -fx-background-radius: 4; -fx-border-radius: 4; -fx-border-color: #6c757d;" />

                <Button layoutX="145.0" layoutY="250.0" mnemonicParsing="false" onAction="#fechar" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Cancelar" />
                <Button layoutX="245.0" layoutY="250.0" mnemonicParsing="false" onAction="#salvarConfiguracao" prefHeight="32.0" prefWidth="160.0" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Salvar e Conectar!" />
            </children>
        </AnchorPane>
    </children>
</AnchorPane>