                                <Label layoutX="462.0" layoutY="24.0" text="Data de Criação: " />
                                <DatePicker fx:id="dpDataCriacao" layoutX="552.0" layoutY="20.0" promptText="01/01/2026" />
        
                                <Label layoutX="735.0" layoutY="24.0" text="P.O.D" />
                                <ComboBox fx:id="cbPod" editable="true" layoutX="773.0" layoutY="20.0" prefHeight="26.0" prefWidth="94.0" promptText="8" />
        
                                <Label layoutX="13.0" layoutY="69.0" text="Razão Social:">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtRazaoSocial" layoutX="97.0" layoutY="65.0" prefHeight="26.0" prefWidth="359.0" promptText="Nome da empresa" />
        
