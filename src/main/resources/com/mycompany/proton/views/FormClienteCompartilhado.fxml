        <Button layoutX="596.0" layoutY="357.0" mnemonicParsing="false" onAction="#cancelar" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" />

        <Button layoutX="731.0" layoutY="357.0" mnemonicParsing="false" onAction="#salvarCliente" prefHeight="32.0" prefWidth="134.0" style="-fx-background-color: #198754; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Salvar Cadastro!">
