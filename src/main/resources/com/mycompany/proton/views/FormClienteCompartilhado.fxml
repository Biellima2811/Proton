                                <Button layoutX="690.0" layoutY="10.0" mnemonicParsing="false" onAction="#adicionarBanco" prefHeight="26.0" prefWidth="170.0" style="-fx-background-color: #198754; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Adicionar à Lista" />

                                <Label layoutX="14.0" layoutY="50.0" text="Usuário DB:" />
                                <ComboBox fx:id="cbUserBanco" editable="true" layoutX="80.0" layoutY="46.0" prefHeight="26.0" prefWidth="100.0" promptText="SYSDBA" />
                                
