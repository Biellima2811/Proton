                                <Label layoutX="450.0" layoutY="124.0" text="Usuário BD:" />
                                <TextField fx:id="txtWsUserBd" layoutX="520.0" layoutY="120.0" prefHeight="26.0" prefWidth="120.0" promptText="sysdba" />

                                <Label layoutX="660.0" layoutY="124.0" text="Senha BD:" />
                                <TextField fx:id="txtWsSenhaBd" layoutX="725.0" layoutY="120.0" prefHeight="26.0" prefWidth="140.0" promptText="senha" />

