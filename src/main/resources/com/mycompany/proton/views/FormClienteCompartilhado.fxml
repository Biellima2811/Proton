                                <Label layoutX="390.0" layoutY="50.0" text="Caminho Físico:" />
                                <TextField fx:id="txtDbConexao" layoutX="480.0" layoutY="46.0" prefHeight="26.0" prefWidth="380.0" promptText="C:\Fortes\BDS\Dados\Nome_Cliente\ABC_AC_123.FDB" />

                                <TableView fx:id="tabelaBancos" layoutX="14.0" layoutY="85.0" prefHeight="130.0" prefWidth="850.0">
                                    <columns>
                                        <TableColumn fx:id="colBancoServidor" prefWidth="120.0" text="Servidor IP" />
                                        <TableColumn fx:id="colBancoNome" prefWidth="150.0" text="Database" />
                                        <TableColumn fx:id="colBancoSgbd" prefWidth="80.0" text="SGBD" />
                                        <TableColumn fx:id="colBancoCaminho" prefWidth="250.0" text="Caminho Físico" />
                                        <TableColumn fx:id="colBancoUsuario" prefWidth="100.0" text="Usuário DB" />
                                        <TableColumn fx:id="colBancoSenha" prefWidth="100.0" text="Senha DB" />
                                    </columns>
                                </TableView>

                                <Button layoutX="14.0" layoutY="225.0" mnemonicParsing="false" onAction="#removerBanco" prefHeight="26.0" prefWidth="150.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-cursor: hand;" text="Remover Selecionado" />
