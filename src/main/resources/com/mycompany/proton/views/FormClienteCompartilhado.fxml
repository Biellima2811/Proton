                                <Label layoutX="312.0" layoutY="114.0" text="Sistemas:" />
                                <TextField fx:id="txtSistemas" layoutX="366.0" layoutY="110.0" prefHeight="26.0" prefWidth="175.0" promptText="Ex: AC, AG, Ponto" />
        
                                <Label layoutX="555.0" layoutY="114.0" text="Status:" />
