                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" style="-fx-background-color: #ffffff;">
                            <children>
                                <Label layoutX="14.0" layoutY="24.0" text="E-mail do Usuário:">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtEmailUsuario" layoutX="125.0" layoutY="20.0" prefHeight="26.0" prefWidth="320.0" promptText="colaborador@empresa.com.br" />
                                
                                <Button layoutX="460.0" layoutY="20.0" mnemonicParsing="false" onAction="#inserirEmail" prefWidth="80.0" style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Inserir" />
                                <Button layoutX="550.0" layoutY="20.0" mnemonicParsing="false" onAction="#importarCsv" prefWidth="120.0" style="-fx-background-color: #6f42c1; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Importar CSV" />
                                
                                <TableView fx:id="tabelaEmails" layoutX="14.0" layoutY="65.0" prefHeight="185.0" prefWidth="850.0">
